---
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import { landingContent } from '@/content/landing';
---
<Section id="blk-04">
  <Container>
    <div class="surface" style="padding:1.25rem">
      <h2 class="h2">{landingContent.sections.blk04.title}</h2>
      <ol style="margin:0.75rem 0 0; padding-left:1rem; display:grid; gap:0.5rem;">
        {landingContent.sections.blk04.steps.map((step) => (
          <li>{step}</li>
        ))}
      </ol>
      <a href="#lead-form" class="btn btn-secondary" style="margin-top:0.75rem">Записаться и выбрать ближайший слот</a>
    </div>
  </Container>
</Section>
