---
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import { HeroVariant } from './HeroVariant';
import { LeadForm } from './LeadForm';
import { landingContent } from '@/content/landing';
---
<Section id="blk-01" class="hero-section">
  <Container>
    <div class="hero-shell">
      <div class="hero-copy">
        <img class="hero-logo" src="/brand/logo-darky.png" alt="Логотип D’Arky Dance" width="512" height="362" loading="eager" decoding="async" />
        <HeroVariant client:load ctaMain={landingContent.ctaMain} microtrustLine={landingContent.microtrustLine} />
      </div>

      <div class="hero-visual" aria-hidden="true">
        <img
          src="/hero/hero-couple.jpg"
          alt=""
          width="1366"
          height="768"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>

      <div class="hero-form-wrap">
        <LeadForm client:load mode="compact" formId="lead-form" source="hero" />
      </div>
    </div>
  </Container>
</Section>
