---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Lady Style — D’Arky Dance" description="Маршрут под направление Lady Style. На этапе MVP остаётся заглушкой до отдельного оффера.">
  <main class="section">
    <div class="container surface" style="padding:1.5rem; max-width:760px; margin-inline:auto;">
      <h1 class="h2">Lady Style — отдельная страница будет добавлена в следующей итерации</h1>
      <p class="muted">Сейчас приоритет в трафике у лендинга парной бачаты для новичков.</p>
      <a class="btn btn-secondary" href="/">Перейти на главный лендинг</a>
    </div>
  </main>
</BaseLayout>
