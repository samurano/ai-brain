---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Парная бачата — D’Arky Dance" description="Маршрут под направление парной бачаты. На этапе MVP ведёт на главный лендинг.">
  <main class="section">
    <div class="container surface" style="padding:1.5rem; max-width:760px; margin-inline:auto;">
      <h1 class="h2">Парная бачата для новичков</h1>
      <p class="muted">На этапе MVP основной маршрут находится на главной странице лендинга.</p>
      <a class="btn btn-secondary" href="/">Перейти на лендинг</a>
    </div>
  </main>
</BaseLayout>
